# ─────────────────────────────────────────────────────────────────────────────
# AML/KYC/CDD Compliance Portal — Environment Variables Template
# Copy to .env and fill in all values before running the application.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Node Environment ─────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Backend Port ─────────────────────────────────────────────────────────────
PORT=3001

# ─── Frontend URL ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
POSTGRES_DB=aml_kyc_db
POSTGRES_USER=aml_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://aml_user:CHANGE_ME_STRONG_PASSWORD_HERE@localhost:5432/aml_kyc_db?schema=public

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_DIFFERENT_SECRET_FOR_REFRESH
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256 key for document encryption at rest (32 bytes hex)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ─── S3-Compatible Object Storage (MinIO / AWS S3 / etc.) ────────────────────
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=aml-documents
MINIO_ACCESS_KEY=CHANGE_ME_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_SECRET_KEY
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false

# ─── Email Service ────────────────────────────────────────────────────────────
# Provider: sendgrid | ses | smtp
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@csp.ae
SMTP_PASSWORD=CHANGE_ME_EMAIL_PASSWORD
EMAIL_FROM=noreply@csp.ae

# ─── SMS / OTP Provider ───────────────────────────────────────────────────────
# Provider: twilio | aws_sns | custom
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=CHANGE_ME_TWILIO_SID
TWILIO_AUTH_TOKEN=CHANGE_ME_TWILIO_TOKEN
TWILIO_FROM_NUMBER=+1234567890

# ─── ID Verification Provider ─────────────────────────────────────────────────
# Provider: jumio | onfido | veriff | mock
ID_VERIFICATION_PROVIDER=mock
ID_VERIFICATION_API_KEY=CHANGE_ME_ID_VERIFICATION_KEY
ID_VERIFICATION_API_URL=https://api.jumio.com
ID_VERIFICATION_PROVIDER_ENABLED=false

# ─── Sanctions Screening Provider ─────────────────────────────────────────────
# Provider: complyadvantage | refinitiv | dow_jones | mock
SANCTIONS_PROVIDER=mock
SANCTIONS_API_KEY=CHANGE_ME_SANCTIONS_API_KEY
SANCTIONS_API_URL=https://api.complyadvantage.com
SANCTIONS_PROVIDER_ENABLED=false

# ─── PEP Database ─────────────────────────────────────────────────────────────
PEP_PROVIDER=mock
PEP_API_KEY=CHANGE_ME_PEP_API_KEY

# ─── Adverse Media ────────────────────────────────────────────────────────────
ADVERSE_MEDIA_PROVIDER=mock
ADVERSE_MEDIA_API_KEY=CHANGE_ME_ADVERSE_MEDIA_KEY

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=100
OTP_RATE_LIMIT_MAX=5
OTP_TTL_SECONDS=300

# ─── Data Residency ───────────────────────────────────────────────────────────
DATA_RESIDENCY_REGION=UAE
AUDIT_LOG_RETENTION_YEARS=6

# ─── Security ─────────────────────────────────────────────────────────────────
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET
SESSION_SECURE=true
CORS_ORIGIN=http://localhost:3000
TLS_ENABLED=false

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# IMPORTANT: Never log PII. This is enforced in AuditService.sanitizeDetails()
