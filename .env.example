# ─── Telemetry opt-out ───────────────────────────────────────────────────────
# Disable Next.js anonymous build telemetry (prevents outbound calls to
# telemetry.nextjs.org, which is blocked in firewall-restricted environments).
NEXT_TELEMETRY_DISABLED=1

# Disable Prisma version-checkpoint calls (prevents outbound calls to
# checkpoint.prisma.io, which is blocked in firewall-restricted environments).
CHECKPOINT_DISABLE=1

# ─── Supabase ────────────────────────────────────────────────────────────────
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Project Settings → API → Project API Keys → anon / public
# Safe to expose to the browser. RLS policies enforce all access control.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Project Settings → API → Project API Keys → service_role
# ⚠ SERVER ONLY — never expose in client code or commit to version control.
# Used exclusively in app/api/ route handlers. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Application ─────────────────────────────────────────────────────────────
# Public base URL of this deployment (no trailing slash).
# Used for auth callback URLs and email link generation.
# Local:   http://localhost:3000
# Staging: https://aml-kyc-cdd-portal-git-staging.vercel.app (or custom domain)
# Prod:    https://app.truvis.io (or equivalent)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Resend (transactional email) ────────────────────────────────────────────
# resend.com → API Keys. Server-only; never expose to the browser.
# When unset, email send is a no-op (status='failed' / error='not_configured'
# is recorded in notification_events; case actions still succeed).
RESEND_API_KEY=

# Verified sender on a domain with SPF/DKIM/DMARC configured at your DNS
# provider. Resend rejects sends from unverified domains.
RESEND_FROM_ADDRESS=compliance@example.com

# Optional Reply-To header (e.g. a monitored shared inbox).
RESEND_REPLY_TO=

# ─── UAE Pass (national digital identity bridge) ─────────────────────────────
# https://docs.uaepass.ae/  (OIDC). When UAE_PASS_CLIENT_ID is unset the bridge
# is treated as not configured: tenant admins can flip the per-tenant flag on
# but the customer-facing button stays hidden and the API routes return 503.
#
# Acquire credentials by registering a Service Provider with TDRA:
#   - Staging: https://stg-id.uaepass.ae/  (sandbox; no real Emirates IDs)
#   - Production: https://id.uaepass.ae/
#
# UAE_PASS_DISCOVERY_URL is the OIDC discovery document of the chosen
# environment; the rest of the endpoints (authorize/token/userinfo/jwks_uri)
# are resolved from it at startup.
UAE_PASS_DISCOVERY_URL=https://stg-id.uaepass.ae/idshub/.well-known/openid-configuration
UAE_PASS_CLIENT_ID=
UAE_PASS_CLIENT_SECRET=
# Optional. Defaults to NEXT_PUBLIC_APP_URL + /api/auth/uae-pass/callback.
UAE_PASS_REDIRECT_URI=
# Optional. Comma-separated scopes. Default covers the general profile claims
# (fullname, idn / Emirates ID, dob, nationality, mobile, email, userType).
UAE_PASS_SCOPES=urn:uae:digitalid:profile:general
# Optional. ACR values (sets the assurance level requested at the IdP).
UAE_PASS_ACR_VALUES=urn:safelayer:tws:policies:authentication:level:low:mobileondemand

# ─── Google Sheets (Docs-Sync live updates) ──────────────────────────────────
# Service account JSON key for writing to the TruVis Command Center spreadsheet.
# Create a service account in Google Cloud Console, grant it "Editor" access to
# the spreadsheet, then paste the entire JSON key (single-line) here.
# When unset, Docs-Sync reports rows to update manually instead of writing live.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Spreadsheet ID from the sheet URL (between /d/ and /edit).
# Defaults to the TruVis AML/KYC/CDD Full SaaS Command Center if unset.
GOOGLE_SHEETS_SPREADSHEET_ID=1Xbi2tkMjwa6qrbxXRQTvvuOIegje0j1M

# ─── Notes ───────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real credentials.
#
# CI/CD: store as GitHub Actions secrets (repo Settings → Secrets → Actions).
# Vercel: configure via Project Settings → Environment Variables.
#   NEXT_PUBLIC_* → all environments.
#   SUPABASE_SERVICE_ROLE_KEY → Production + Preview only (not Development).
#
# Validate that all required vars are present: npm run validate:env
