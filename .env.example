# ─── Supabase ────────────────────────────────────────────────────────────────
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Project Settings → API → Project API Keys → anon / public
# Safe to expose to the browser. RLS policies enforce all access control.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Project Settings → API → Project API Keys → service_role
# ⚠ SERVER ONLY — never expose in client code or commit to version control.
# Used exclusively in app/api/ route handlers. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Application ─────────────────────────────────────────────────────────────
# Public base URL of this deployment (no trailing slash).
# Used for auth callback URLs and email link generation.
# Local:   http://localhost:3000
# Staging: https://aml-kyc-cdd-portal-git-staging.vercel.app (or custom domain)
# Prod:    https://app.truvis.io (or equivalent)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Notes ───────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real credentials.
#
# CI/CD: store as GitHub Actions secrets (repo Settings → Secrets → Actions).
# Vercel: configure via Project Settings → Environment Variables.
#   NEXT_PUBLIC_* → all environments.
#   SUPABASE_SERVICE_ROLE_KEY → Production + Preview only (not Development).
#
# Validate that all required vars are present: npm run validate:env
